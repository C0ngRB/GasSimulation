#include "Simulator.h"

#include <algorithm>
#include <cmath>

static inline double deg2rad(double d) { return d * M_PI / 180.0; }

void Simulator::initialize(const SimParams &p)
{
    params_ = p;
    t_ = 0.0;

    Nx_ = std::max(2, p.Nx);
    Ny_ = std::max(2, p.Ny);
    dx_ = p.Lx / (Nx_ - 1);
    dy_ = p.Ly / (Ny_ - 1);

    C_.assign(Nx_ * Ny_, 0.0f);
    Cn_.assign(Nx_ * Ny_, 0.0f);

    const double th = deg2rad(p.windDir);
    u_ = p.windSpeed * std::cos(th);
    v_ = p.windSpeed * std::sin(th);
}

void Simulator::step()
{
    const double dt = params_.dt;
    const double D = params_.D;
    const double decay = params_.decay;

    const double srcR = params_.srcRadius;
    const double srcR2 = srcR * srcR;

    for (int j = 0; j < Ny_; ++j)
    {
        const double y = j * dy_;
        for (int i = 0; i < Nx_; ++i)
        {
            const double x = i * dx_;
            const int id = j * Nx_ + i;

            const double c = C_[id];

            auto get = [&](int ii, int jj) -> double
            {
                if (ii < 0 || ii >= Nx_ || jj < 0 || jj >= Ny_)
                    return 0.0;
                return C_[jj * Nx_ + ii];
            };

            const double cL = get(i - 1, j);
            const double cR = get(i + 1, j);
            const double cD = get(i, j - 1);
            const double cU = get(i, j + 1);

            const double dc_dx = (u_ >= 0) ? (c - cL) / dx_ : (cR - c) / dx_;
            const double dc_dy = (v_ >= 0) ? (c - cD) / dy_ : (cU - c) / dy_;

            const double lap = (cL - 2 * c + cR) / (dx_ * dx_) + (cD - 2 * c + cU) / (dy_ * dy_);

            double cn = c + dt * (-(u_ * dc_dx + v_ * dc_dy) + D * lap - decay * c);

            const double dxs = x - params_.srcX;
            const double dys = y - params_.srcY;
            if (dxs * dxs + dys * dys <= srcR2)
                cn += dt * params_.sourceRate;

            cn = std::max(0.0, cn);
            Cn_[id] = (float)cn;
        }
    }

    C_.swap(Cn_);
    t_ += dt;
}

double Simulator::time() const
{
    return t_;
}

int Simulator::Nx() const { return Nx_; }
int Simulator::Ny() const { return Ny_; }
const std::vector<float> &Simulator::field() const { return C_; }
