#include "TerrainDem.h"

#include <fstream>
#include <sstream>
#include <algorithm>
#include <cmath>

static bool readAllBytes(const std::string &path, std::vector<char> &out)
{
    std::ifstream f(path, std::ios::binary);
    if (!f)
        return false;
    f.seekg(0, std::ios::end);
    const auto n = (size_t)f.tellg();
    f.seekg(0, std::ios::beg);
    out.resize(n);
    f.read(out.data(), (std::streamsize)n);
    return true;
}

static bool parseMeta(const std::string &json,
                      int &w, int &h,
                      double &xMin, double &yMin,
                      double &dx, double &dy)
{
    auto findNum = [&](const std::string &key, double &val) -> bool
    {
        const auto pos = json.find(key);
        if (pos == std::string::npos)
            return false;
        const auto colon = json.find(':', pos);
        if (colon == std::string::npos)
            return false;
        size_t start = colon + 1;
        while (start < json.size() && (json[start] == ' ' || json[start] == '\t'))
            ++start;
        size_t end = start;
        while (end < json.size() && (std::isdigit((unsigned char)json[end]) || json[end] == '.' || json[end] == '-' || json[end] == 'e' || json[end] == 'E' || json[end] == '+'))
            ++end;
        try
        {
            val = std::stod(json.substr(start, end - start));
            return true;
        }
        catch (...)
        {
            return false;
        }
    };

    double ww = 0, hh = 0;
    if (!findNum("\"width\"", ww))
        return false;
    if (!findNum("\"height\"", hh))
        return false;

    w = (int)ww;
    h = (int)hh;

    if (!findNum("\"x_min\"", xMin))
        return false;
    if (!findNum("\"y_min\"", yMin))
        return false;
    if (!findNum("\"dx\"", dx))
        return false;
    if (!findNum("\"dy\"", dy))
        return false;

    return true;
}

bool TerrainDem::load(const std::string &metaPath, const std::string &binPath)
{
    std::ifstream mf(metaPath);
    if (!mf)
        return false;
    std::stringstream ss;
    ss << mf.rdbuf();
    const std::string json = ss.str();

    if (!parseMeta(json, w_, h_, xMin_, yMin_, dx_, dy_))
        return false;

    std::vector<char> bytes;
    if (!readAllBytes(binPath, bytes))
        return false;

    const size_t n = (size_t)w_ * (size_t)h_;
    if (bytes.size() != n * sizeof(float))
        return false;

    data_.resize(n);
    std::memcpy(data_.data(), bytes.data(), bytes.size());

    xMax_ = xMin_ + dx_ * (w_ - 1);
    yMax_ = yMin_ + dy_ * (h_ - 1);

    valid_ = true;
    return true;
}

float TerrainDem::height(double x, double y) const
{
    if (!valid_ || w_ <= 1 || h_ <= 1)
        return 0.0f;

    const double fx = (x - xMin_) / dx_;
    const double fy = (y - yMin_) / dy_;

    const double fxC = std::clamp(fx, 0.0, (double)(w_ - 1));
    const double fyC = std::clamp(fy, 0.0, (double)(h_ - 1));

    const int x0 = (int)std::floor(fxC);
    const int y0 = (int)std::floor(fyC);
    const int x1 = std::min(x0 + 1, w_ - 1);
    const int y1 = std::min(y0 + 1, h_ - 1);

    const double tx = fxC - x0;
    const double ty = fyC - y0;

    auto at = [&](int xi, int yi) -> double
    {
        const size_t id = (size_t)yi * (size_t)w_ + (size_t)xi;
        return data_[id];
    };

    const double v00 = at(x0, y0);
    const double v10 = at(x1, y0);
    const double v01 = at(x0, y1);
    const double v11 = at(x1, y1);

    const double v0 = v00 * (1.0 - tx) + v10 * tx;
    const double v1 = v01 * (1.0 - tx) + v11 * tx;

    return (float)(v0 * (1.0 - ty) + v1 * ty);
}
