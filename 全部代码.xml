#include "ExternalCfdBackend.h"

#include <QDir>
#include <QFileInfo>
#include <QProcess>
#include <QTimer>

#include <fstream>

ExternalCfdBackend::ExternalCfdBackend(QObject *parent) : QObject(parent)
{
    pollTimer_ = new QTimer(this);
    pollTimer_->setInterval(200);
    connect(pollTimer_, &QTimer::timeout, this, &ExternalCfdBackend::pollFrames);
}

void ExternalCfdBackend::setWorkingDir(const QString &dir)
{
    workDir_ = dir;
}

void ExternalCfdBackend::setRunner(const QString &runner)
{
    runner_ = runner;
}

void ExternalCfdBackend::start(const SimParams &p)
{
    params_ = p;
    nextIdx_ = 0;
    running_ = true;

    QDir().mkpath(workDir_);
    QDir().mkpath(QDir(workDir_).filePath("frames"));

    const QString paramsPath = QDir(workDir_).filePath("params.json");
    std::ofstream f(paramsPath.toStdString());
    f << "{\n";
    f << "  \"Lx\": " << p.Lx << ",\n";
    f << "  \"Ly\": " << p.Ly << ",\n";
    f << "  \"Nx\": " << p.Nx << ",\n";
    f << "  \"Ny\": " << p.Ny << ",\n";
    f << "  \"windSpeed\": " << p.windSpeed << ",\n";
    f << "  \"windDir\": " << p.windDir << ",\n";
    f << "  \"D\": " << p.D << ",\n";
    f << "  \"decay\": " << p.decay << ",\n";
    f << "  \"srcX\": " << p.srcX << ",\n";
    f << "  \"srcY\": " << p.srcY << ",\n";
    f << "  \"srcRadius\": " << p.srcRadius << ",\n";
    f << "  \"sourceRate\": " << p.sourceRate << ",\n";
    f << "  \"dt\": " << p.dt << ",\n";
    f << "  \"totalTime\": " << p.totalTime << "\n";
    f << "}\n";
    f.close();

    if (!runner_.isEmpty())
    {
        QProcess::startDetached(runner_, {}, workDir_);
    }

    pollTimer_->start();
}

void ExternalCfdBackend::stop()
{
    running_ = false;
    pollTimer_->stop();
}

void ExternalCfdBackend::pollFrames()
{
    if (!running_)
        return;

    QString framePath = QDir(workDir_).filePath(QString("frames/frame_%1.csv").arg(nextIdx_, 4, 10, QChar('0')));
    if (!QFileInfo::exists(framePath))
        return;

    CsvFrameReader::Frame fr;
    std::string err;
    if (!CsvFrameReader::read(framePath.toStdString(), fr, err))
        return;

    ++nextIdx_;
    emit frameReady(fr);
}
