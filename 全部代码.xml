#include "CsvFrameReader.h"

#include <fstream>
#include <sstream>
#include <string>

bool CsvFrameReader::read(const std::string &path, Frame &out, std::string &err)
{
    std::ifstream f(path);
    if (!f)
    {
        err = "open failed";
        return false;
    }

    std::string line;
    bool haveMeta = false;
    bool haveGrid = false;

    Frame fr;

    while (std::getline(f, line))
    {
        if (line.empty())
            continue;
        if (line[0] == '#')
        {
            auto pos = line.find(':');
            if (pos != std::string::npos)
            {
                std::string key = line.substr(1, pos - 1);
                std::string val = line.substr(pos + 1);
                while (!key.empty() && (key.back() == ' ' || key.back() == '\t'))
                    key.pop_back();
                while (!val.empty() && (val.front() == ' ' || val.front() == '\t'))
                    val.erase(val.begin());
                fr.meta[key] = val;
                haveMeta = true;
            }
            continue;
        }

        {
            std::stringstream ss(line);
            std::string tok;
            std::vector<float> row;
            while (std::getline(ss, tok, ','))
            {
                try
                {
                    row.push_back(std::stof(tok));
                }
                catch (...)
                {
                }
            }
            if (!row.empty())
            {
                fr.grid.push_back(std::move(row));
                haveGrid = true;
            }
        }
    }

    if (!haveGrid)
    {
        err = "no grid data";
        return false;
    }

    fr.Ny = (int)fr.grid.size();
    fr.Nx = (int)fr.grid[0].size();
    for (auto &r : fr.grid)
    {
        if ((int)r.size() != fr.Nx)
        {
            err = "inconsistent row length";
            return false;
        }
    }

    out = std::move(fr);
    return true;
}
