    connect(sbDy_, qOverload<double>(&QDoubleSpinBox::valueChanged), this, &MainWindow::onTerrainParamsChanged);

    connect(cbModel_, qOverload<int>(&QComboBox::currentIndexChanged), this, [this](int) {
        running_ = false;
        timer_->stop();
