/**
 * @brief 读取外部 CFD 输出的 CSV 帧。
 *
 * CSV 约定：
 * - 可选头行：# Nx=300 Ny=150 t=0.50
 * - 后续 Ny 行，每行 Nx 个 float，用逗号分隔（行=Y，列=X）
 */
class CsvFrameReader {
